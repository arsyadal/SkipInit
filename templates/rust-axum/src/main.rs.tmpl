use axum::{response::Json, routing::get, Router};
use serde::Serialize;

#[derive(Serialize)]
struct StatusResponse {
    message: String,
    project_name: String,
    database: String,
}

#[tokio::main]
async fn main() {
    // Database initialization
    {{#hasPostgres}}
    let database_url = std::env::var("DATABASE_URL").unwrap_or_else(|_| "postgres://postgres:password@localhost:5432/{{projectNameSlug}}".to_string());
    let _pool = sqlx::PgPool::connect(&database_url).await.expect("Failed to connect to Postgres");
    {{/hasPostgres}}
    {{#hasMysql}}
    let database_url = std::env::var("DATABASE_URL").unwrap_or_else(|_| "mysql://root:password@localhost:3306/{{projectNameSlug}}".to_string());
    let _pool = sqlx::MySqlPool::connect(&database_url).await.expect("Failed to connect to MySQL");
    {{/hasMysql}}
    {{#hasSqlite}}
    let database_url = std::env::var("DATABASE_URL").unwrap_or_else(|_| "sqlite://db.sqlite".to_string());
    let _pool = sqlx::SqlitePool::connect(&database_url).await.expect("Failed to connect to SQLite");
    {{/hasSqlite}}
    {{#hasMongodb}}
    let mongodb_uri = std::env::var("DATABASE_URL").unwrap_or_else(|_| "mongodb://localhost:27017/".to_string());
    let client_options = mongodb::options::ClientOptions::parse(&mongodb_uri).await.expect("Failed to parse MongoDB URI");
    let _client = mongodb::Client::with_options(client_options).expect("Failed to create MongoDB client");
    {{/hasMongodb}}
    {{#hasRedis}}
    let redis_uri = std::env::var("REDIS_URL").unwrap_or_else(|_| "redis://127.0.0.1/".to_string());
    let _client = redis::Client::open(redis_uri).expect("Failed to open Redis connection");
    {{/hasRedis}}

    let app = Router::new().route("/", get(handler));

    let listener = tokio::net::TcpListener::bind("0.0.0.0:3000")
        .await
        .unwrap();
    println!("Listening on: http://0.0.0.0:3000");
    axum::serve(listener, app).await.unwrap();
}

async fn handler() -> Json<StatusResponse> {
    Json(StatusResponse {
        message: "Hello from Rust Axum. SkipInit template.".to_string(),
        project_name: "{{projectName}}".to_string(),
        database: "{{databaseLabel}}".to_string(),
    })
}
