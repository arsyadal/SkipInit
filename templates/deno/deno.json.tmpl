{
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-env src/main.ts",
    "start": "deno run --allow-net --allow-env src/main.ts"
  },
  "imports": {
    "hono": "npm:hono"{{#hasPostgres}},
    "pg": "npm:pg"{{/hasPostgres}}{{#hasMysql}},
    "mysql2": "npm:mysql2"{{/hasMysql}}{{#hasRedis}},
    "redis": "npm:redis"{{/hasRedis}}{{#hasMssql}},
    "mssql": "npm:mssql"{{/hasMssql}}{{#hasMongodb}},
    "mongodb": "npm:mongodb"{{/hasMongodb}}{{#hasJwt}},
    "jsonwebtoken": "npm:jsonwebtoken"{{/hasJwt}}
  }
}
