services:
  app:
    build: .
    ports:
      - "8080:8080"
{{#hasPostgres}}
    environment:
      ConnectionStrings__DefaultConnection: "Host=db;Database={{projectNameSlug}};Username=postgres;Password=password"
    depends_on:
      - db
{{/hasPostgres}}
{{#hasPostgres}}

  db:
    image: postgres:16-alpine
    restart: unless-stopped
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: password
      POSTGRES_DB: {{projectNameSlug}}
    ports:
      - "5432:5432"
    volumes:
      - db-data:/var/lib/postgresql/data

volumes:
  db-data:
{{/hasPostgres}}
