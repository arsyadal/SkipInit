default: &default
  adapter: {{#hasPostgres}}postgresql{{/hasPostgres}}{{#hasMysql}}mysql2{{/hasMysql}}{{^hasPostgres}}{{^hasMysql}}sqlite3{{/hasMysql}}{{/hasPostgres}}
  pool: <%= ENV.fetch("RAILS_MAX_THREADS") { 5 } %>
  timeout: 5000

development:
  <<: *default
{{#hasPostgres}}
  host: localhost
  database: {{projectNameSlug}}_development
  username: postgres
  password: <%= ENV["DB_PASSWORD"] %>
{{/hasPostgres}}
{{#hasMysql}}
  host: localhost
  database: {{projectNameSlug}}_development
  username: root
  password: <%= ENV["DB_PASSWORD"] %>
{{/hasMysql}}
{{^hasPostgres}}{{^hasMysql}}
  database: db/development.sqlite3
{{/hasMysql}}{{/hasPostgres}}
