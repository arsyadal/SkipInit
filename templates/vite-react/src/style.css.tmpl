:root {
  color: #181512;
  background: #f6f0df;
  font-family: ui-serif, Georgia, serif;
}

body {
  margin: 0;
}

main {
  min-height: 100vh;
  display: grid;
  place-content: center;
  padding: 48px;
}

h1 {
  margin: 0;
  font-size: clamp(48px, 9vw, 120px);
  line-height: 0.9;
}

p {
  max-width: 520px;
  font-size: 20px;
}

.eyebrow {
  font: 700 12px/1 ui-monospace, SFMono-Regular, Menlo, monospace;
  letter-spacing: 0.18em;
  text-transform: uppercase;
}
